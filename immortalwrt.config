#
# Automatically generated file; DO NOT EDIT.
# ImmortalWrt Configuration
# 基于第一份文件，合并第二份文件 + 完整优化（含 NTP）
# 已清理重复、冲突和冗余配置
# 适用于: Bell XG-040G-MD (Airoha AN7581)
# 包管理器: APK (OpenWrt 6.12+ 默认)
#

# ============================================
# 核心 - 平台与设备
# ============================================
CONFIG_TARGET_airoha=y
CONFIG_TARGET_airoha_an7581=y
CONFIG_TARGET_airoha_an7581_DEVICE_bell_xg-040g-md=y
CONFIG_TARGET_DEVICE_airoha_an7581_bell-xg-040g-md=y
CONFIG_TARGET_DEVICE_PACKAGES_airoha_an7581_bell-xg-040g-md=""
CONFIG_ARCH_64BIT=y
CONFIG_aarch64=y
CONFIG_LINUX_6_12=y

# ============================================
# 核心 - 镜像格式
# ============================================
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y

# ============================================
# 核心 - 内核基础选项
# ============================================
CONFIG_JSON_OVERVIEW_IMAGE_INFO=y
CONFIG_KERNEL_BUILD_USER="ImmortalWrt"
CONFIG_KERNEL_BUILD_DOMAIN="immortalwrt.local"
CONFIG_IPV6=y
CONFIG_CPU_TYPE="cortex-a53"

# ============================================
# Airoha 硬件专用驱动
# ============================================
CONFIG_PACKAGE_airoha-en7581-npu-firmware=y
CONFIG_PACKAGE_kmod-i2c-an7581=y

# ============================================
# 核心 - EN8811H PHY 驱动 (完整版)
# ============================================
CONFIG_PACKAGE_kmod-phy-en8811h=y
CONFIG_PACKAGE_kmod-phy-airoha-en8811h=y
CONFIG_PACKAGE_airoha-en8811h-firmware=y

# ============================================
# 核心 - AN7581 以太网 + NPU
# ============================================
CONFIG_PACKAGE_kmod-airoha-eth=y
CONFIG_PACKAGE_kmod-airoha-npu=y
CONFIG_PACKAGE_kmod-airoha-switch=y
CONFIG_AIROHA_ETH=y
CONFIG_AIROHA_RESERVE_NPU_MEMORY=128M

# ============================================
# 核心 - PHY 框架 + 交换机 + MDIO
# ============================================
CONFIG_PHYLIB=y
CONFIG_SWITCHDEV=y
CONFIG_NET_DSA=y
CONFIG_MDIO_BUS=y
CONFIG_KERNEL_NET_SWITCHDEV=y
CONFIG_VLAN_8021Q=y

# ============================================
# 核心 - 网络基础
# ============================================
CONFIG_PACKAGE_dnsmasq=y
# CONFIG_PACKAGE_firewall is not set      # 禁用旧版 iptables 防火墙，使用 firewall4
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_ip-full=y

# ============================================
# 核心 - 硬件加速模块（含 Flow Table 支持）
# ============================================
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_NFT_FLOW_OFFLOAD=y

# ============================================
# 看门狗 - 硬件看门狗 (GPIO)，禁用软看门狗
# ============================================
CONFIG_WATCHDOG=y
CONFIG_GPIO_WATCHDOG=y
# CONFIG_SOFT_WATCHDOG is not set

# ============================================
# 重要 - 闪存与文件系统
# ============================================
CONFIG_PACKAGE_kmod-mtd-rw=y
CONFIG_PACKAGE_kmod-spi-nand=y
CONFIG_PACKAGE_kmod-spi-nor=y
CONFIG_PACKAGE_mtd-utils=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-squashfs=y
CONFIG_PACKAGE_kmod-fs-ubifs=y
CONFIG_PACKAGE_kmod-fs-jffs2=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-nls-cp437=y
CONFIG_PACKAGE_kmod-nls-iso8859-1=y
CONFIG_PACKAGE_kmod-nls-utf8=y
CONFIG_PACKAGE_block-mount=y

# ============================================
# 重要 - USB 支持
# ============================================
CONFIG_USB_SUPPORT=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-dwc3=y
CONFIG_PACKAGE_kmod-usb-dwc3-of-simple=y
CONFIG_PACKAGE_kmod-phy-airoha-usb=y
# CONFIG_PACKAGE_kmod-usb-xhci-mtk is not set  # AN7581 非 MTK 平台，禁用
CONFIG_PACKAGE_kmod-usb-xhci-hcd=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-extras=y
CONFIG_PACKAGE_usbutils=y

# ============================================
# 重要 - 额外内核模块
# ============================================
CONFIG_PACKAGE_kmod-8021q=y
CONFIG_PACKAGE_kmod-ppp-mppe=y
CONFIG_PACKAGE_kmod-macvlan=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-nfnetlink=y
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nf-flow=y
CONFIG_PACKAGE_kmod-nf-socket=y
CONFIG_PACKAGE_kmod-nft-tproxy=y

# ============================================
# 重要 - BBR 拥塞控制
# ============================================
CONFIG_KERNEL_TCP_CONG_BBR=y
CONFIG_KERNEL_DEFAULT_TCP_CONG="bbr"
CONFIG_KERNEL_NET_SCH_FQ=y

# ============================================
# 重要 - OpenSSL
# ============================================
CONFIG_OPENSSL_SMALL_FOOTPRINT=y
CONFIG_OPENSSL_WITH_ASM=y

# ============================================
# 安全加固选项
# ============================================
CONFIG_PKG_ASLR_PIE_REGULAR=y
CONFIG_PKG_CC_STACKPROTECTOR_REGULAR=y
CONFIG_KERNEL_CC_STACKPROTECTOR_REGULAR=y

# ============================================
# 基础系统组件
# ============================================
CONFIG_DEFAULT_base-files=y
CONFIG_DEFAULT_busybox=y
CONFIG_DEFAULT_ca-bundle=y
CONFIG_DEFAULT_logd=y
CONFIG_DEFAULT_procd=y
CONFIG_DEFAULT_uci=y
CONFIG_DEFAULT_urandom-seed=y
CONFIG_DEFAULT_urngd=y
CONFIG_DEFAULT_netifd=y
CONFIG_DEFAULT_mtd=y
CONFIG_DEFAULT_fstools=y
CONFIG_DEFAULT_block-mount=y
CONFIG_DEFAULT_libc=y
CONFIG_DEFAULT_libgcc=y
CONFIG_PACKAGE_uboot-envtools=y
CONFIG_PACKAGE_kmod-ubootenv-nvram=y
CONFIG_PACKAGE_uclient-fetch=y
CONFIG_PACKAGE_kmod-gpio-button-hotplug=y
CONFIG_PACKAGE_kmod-leds-gpio=y
CONFIG_PACKAGE_ubi-utils=y
CONFIG_MTD_UBI=y
CONFIG_UBIFS_FS=y

# ============================================
# 网络组件
# ============================================
CONFIG_DEFAULT_odhcp6c=y
CONFIG_DEFAULT_odhcpd-ipv6only=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_ethtool-full=y

# ============================================
# 包管理器：apk
# ============================================
CONFIG_PACKAGE_apk=y
CONFIG_DEFAULT_apk-tools=y
CONFIG_PACKAGE_apk-mbedtls=y
CONFIG_DEFAULT_openwrt-keyring=y

# ============================================
# SSH
# ============================================
CONFIG_PACKAGE_dropbear=y
CONFIG_DROPBEAR_SMALL_CODE=y
CONFIG_DROPBEAR_ED25519=y
CONFIG_DROPBEAR_CURVE25519=y

# ============================================
# 文件系统工具 (extroot)
# ============================================
CONFIG_PACKAGE_fitblk=y
CONFIG_PACKAGE_blkid=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_e2fsprogs=y

# ============================================
# 可选 - LuCI 界面
# ============================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl-openssl=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-package-manager=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-app-attendedsysupgrade=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-theme-bootstrap=y

# ============================================
# 可选 - 中文语言包
# ============================================
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_luci-i18n-homeproxy-zh-cn=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y

# ============================================
# 可选 - PassWall 插件
# ============================================
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_iptables-mod-tproxy=y
CONFIG_PACKAGE_iptables-mod-socket=y
CONFIG_PACKAGE_kmod-ipt-nat=y
CONFIG_PACKAGE_kmod-ipt-ipset=y
CONFIG_PACKAGE_kmod-ipt-fullconenat=y
CONFIG_PACKAGE_ipt2socks=y
CONFIG_PACKAGE_dns2socks=y

# ============================================
# 可选 - HomeProxy
# ============================================
CONFIG_PACKAGE_luci-app-homeproxy=y

# ============================================
# 可选 - 系统工具 (精简版，删除了冗余调试包)
# ============================================
CONFIG_PACKAGE_wget-ssl=y
# CONFIG_PACKAGE_ethtool is not set        # 使用 ethtool-full
# CONFIG_PACKAGE_tcpdump is not set        # 可选，需要时可取消注释
# CONFIG_PACKAGE_iperf3 is not set         # 可选，需要时可取消注释
# CONFIG_PACKAGE_mdio-tools is not set     # 可选，需要时可取消注释
# CONFIG_PACKAGE_curl is not set           # wget-ssl 已够用
CONFIG_PACKAGE_fwtool=y
CONFIG_PACKAGE_umdns=y

# ============================================
# 发行版特定配置
# ============================================
CONFIG_PACKAGE_default-settings=y
CONFIG_PACKAGE_default-settings-chn=y

# ============================================
# Build options
# ============================================
CONFIG_DEVEL=y
CONFIG_CCACHE=y
CONFIG_CCACHE_DIR="/mnt/openwrt/ccache"

# ============================================
# 优化配置 1.1 - 修复潜在依赖冲突
# ============================================
# PPP 扩展支持
CONFIG_PACKAGE_kmod-ppp=y
CONFIG_PACKAGE_kmod-pppoe=y
CONFIG_PACKAGE_kmod-pppol2tp=y          # L2TP 支持（某些 ISP 需要）
CONFIG_PACKAGE_kmod-pptp=y              # PPTP 支持

# ============================================
# 优化配置 1.2 - NAND 闪存 ECC 纠错支持
# ============================================
CONFIG_PACKAGE_kmod-nandsim=y
CONFIG_MTD_NAND_ECC=y
CONFIG_MTD_NAND_ECC_SW_HAMMING=y

# ============================================
# 优化配置 2.1 - 内存管理优化
# ============================================
CONFIG_KERNEL_SLUB=y                    # 使用 SLUB 分配器（性能更好）
CONFIG_KERNEL_TRANSPARENT_HUGEPAGE=y    # 透明大页（提升内存性能）
CONFIG_KERNEL_NO_HZ_IDLE=y              # 空闲时关闭定时器（省电）

# ============================================
# 优化配置 2.2 - 网络性能调优
# ============================================
# 网络缓冲区优化
CONFIG_KERNEL_NET_CORE_RMEM_DEFAULT=262144
CONFIG_KERNEL_NET_CORE_WMEM_DEFAULT=262144
CONFIG_KERNEL_NET_CORE_RMEM_MAX=16777216
CONFIG_KERNEL_NET_CORE_WMEM_MAX=16777216

# TCP 优化
CONFIG_KERNEL_TCP_MD5SIG=y              # TCP MD5 签名（安全）
CONFIG_KERNEL_TCP_SACK=y                # 选择性确认

# ============================================
# 优化配置 2.3 - 硬件 RNG 支持
# ============================================
CONFIG_PACKAGE_kmod-hw-random-y
CONFIG_PACKAGE_rng-tools=y

# ============================================
# 优化配置 2.4 - 温度监控
# ============================================
CONFIG_PACKAGE_kmod-thermal=y
CONFIG_PACKAGE_luci-app-temp-status=y   # LuCI 温度显示

# ============================================
# 优化配置 2.5 - NTP 客户端（时间同步）
# ============================================
CONFIG_PACKAGE_ntpd=y
CONFIG_PACKAGE_ntp-utils=y
CONFIG_PACKAGE_luci-app-ntpc=y          # LuCI NTP 配置界面
