#
# Automatically generated file; DO NOT EDIT.
# ImmortalWrt Configuration
# 基于第二份文件修改：添加 CPU_TYPE，修正无效选项，补齐 USB 驱动，添加安全选项与硬件看门狗
# 包管理器由构建系统自动选择（OpenWrt 6.12+ 默认 apk，ImmortalWrt 保持兼容）

# ============================================
# 核心 - 平台与设备
# ============================================
CONFIG_TARGET_airoha=y
CONFIG_TARGET_airoha_an7581=y
CONFIG_TARGET_airoha_an7581_DEVICE_bell_xg-040g-md=y
CONFIG_TARGET_DEVICE_airoha_an7581_bell-xg-040g-md=y
CONFIG_TARGET_DEVICE_PACKAGES_airoha_an7581_bell-xg-040g-md=""

# ============================================
# 核心 - 镜像格式
# ============================================
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y

# ============================================
# 核心 - 内核基础选项
# ============================================
CONFIG_JSON_OVERVIEW_IMAGE_INFO=y
CONFIG_KERNEL_BUILD_USER="ImmortalWrt"
CONFIG_KERNEL_BUILD_DOMAIN="immortalwrt.local"
CONFIG_IPV6=y
CONFIG_CPU_TYPE="cortex-a53"

# ============================================
# 核心 - EN8811H PHY 驱动
# ============================================
CONFIG_PACKAGE_kmod-phy-en8811h=y
CONFIG_PACKAGE_kmod-phy-airoha-en8811h=y
CONFIG_PACKAGE_airoha-en8811h-firmware=y

# ============================================
# 核心 - AN7581 以太网 + NPU
# ============================================
CONFIG_PACKAGE_kmod-airoha-eth=y
CONFIG_PACKAGE_kmod-airoha-npu=y
CONFIG_PACKAGE_kmod-airoha-switch=y
CONFIG_AIROHA_ETH=y
CONFIG_AIROHA_RESERVE_NPU_MEMORY=128M

# ============================================
# 核心 - PHY 框架 + 交换机 + MDIO
# ============================================
CONFIG_PHYLIB=y
CONFIG_SWITCHDEV=y
CONFIG_NET_DSA=y
CONFIG_MDIO_BUS=y
CONFIG_KERNEL_NET_SWITCHDEV=y
CONFIG_VLAN_8021Q=y

# ============================================
# 核心 - 网络基础
# ============================================
CONFIG_PACKAGE_dnsmasq=y
CONFIG_PACKAGE_firewall=y
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y
CONFIG_PACKAGE_iptables-nft=y

# ============================================
# 核心 - 硬件加速模块（含 Flow Table 支持）
# ============================================
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_NFT_FLOW_OFFLOAD=y

# ============================================
# 看门狗 - 硬件看门狗 (GPIO)，禁用软看门狗
# ============================================
CONFIG_WATCHDOG=y
CONFIG_GPIO_WATCHDOG=y
# CONFIG_SOFT_WATCHDOG is not set

# ============================================
# 重要 - 闪存与文件系统
# ============================================
CONFIG_PACKAGE_kmod-mtd-rw=y
CONFIG_PACKAGE_kmod-spi-nand=y
CONFIG_PACKAGE_kmod-spi-nor=y
CONFIG_PACKAGE_mtd-utils=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-squashfs=y
CONFIG_PACKAGE_kmod-fs-ubifs=y
CONFIG_PACKAGE_kmod-fs-jffs2=y
CONFIG_PACKAGE_kmod-nls-cp437=y
CONFIG_PACKAGE_kmod-nls-iso8859-1=y
CONFIG_PACKAGE_kmod-nls-utf8=y
CONFIG_PACKAGE_block-mount=y

# ============================================
# 重要 - USB 支持（已补齐 xHCI 驱动和 UAS 加速）
# ============================================
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-dwc3=y
CONFIG_PACKAGE_kmod-usb-dwc3-of-simple=y
CONFIG_PACKAGE_kmod-phy-airoha-usb=y
CONFIG_PACKAGE_kmod-usb-xhci-mtk=y
CONFIG_PACKAGE_kmod-usb-xhci-hcd=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_usbutils=y

# ============================================
# 重要 - 额外内核模块
# ============================================
CONFIG_PACKAGE_kmod-8021q=y
CONFIG_PACKAGE_kmod-ppp-mppe=y
CONFIG_PACKAGE_kmod-macvlan=y
CONFIG_PACKAGE_kmod-tun=y

# ============================================
# 重要 - BBR 拥塞控制
# ============================================
CONFIG_KERNEL_TCP_CONG_BBR=y
CONFIG_KERNEL_DEFAULT_TCP_CONG="bbr"
CONFIG_KERNEL_NET_SCH_FQ=y

# ============================================
# 重要 - OpenSSL
# ============================================
CONFIG_OPENSSL_SMALL_FOOTPRINT=y
CONFIG_OPENSSL_WITH_ASM=y

# ============================================
# 安全加固选项
# ============================================
CONFIG_PKG_ASLR_PIE_REGULAR=y
CONFIG_PKG_CC_STACKPROTECTOR_REGULAR=y
CONFIG_KERNEL_CC_STACKPROTECTOR_REGULAR=y

# ============================================
# 可选 - LuCI 界面（包管理器前端由系统自动选择）
# ============================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl-openssl=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-package-manager=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-app-attendedsysupgrade=y

# ============================================
# 可选 - 中文语言包
# ============================================
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y

# ============================================
# 可选 - PassWall 插件
# ============================================
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_iptables-mod-tproxy=y
CONFIG_PACKAGE_iptables-mod-socket=y
CONFIG_PACKAGE_kmod-ipt-nat=y
CONFIG_PACKAGE_kmod-ipt-ipset=y
CONFIG_PACKAGE_kmod-ipt-fullconenat=y
CONFIG_PACKAGE_ipt2socks=y
CONFIG_PACKAGE_dns2socks=y

# ============================================
# 可选 - 系统与调试工具
# ============================================
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_ethtool=y
CONFIG_PACKAGE_mdio-tools=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_iperf3=y

# ============================================
# 发行版特定配置（构建时自动适配）
# ============================================
# ImmortalWrt 特有的包（OpenWrt 会忽略）
CONFIG_PACKAGE_default-settings=y
CONFIG_PACKAGE_default-settings-chn=y
