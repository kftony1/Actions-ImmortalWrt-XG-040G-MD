#
# OpenWrt Configuration for Nokia Bell XG-040G-MD (OpenWrt main 6.12)
# 修改：主题 argon，关闭 IPv6，关闭安全加固，精简 USB/文件系统
# 新增：CMA、DMA_CMA、AIROHA_WATCHDOG、I2C、LEDS_TRIGGER_NETDEV、MTD_UBI_BLOCK
#

# ============================================
# Target & Device
# ============================================
CONFIG_TARGET_airoha=y
CONFIG_TARGET_airoha_an7581=y
CONFIG_TARGET_airoha_an7581_DEVICE_bell_xg-040g-md=y
CONFIG_TARGET_DEVICE_PACKAGES_airoha_an7581_bell-xg-040g-md=""

# ============================================
# Kernel & Architecture
# ============================================
CONFIG_ARCH_64BIT=y
CONFIG_aarch64=y
CONFIG_LINUX_6_18=y            # OpenWrt main 内核 6.12 映射
# CONFIG_IPV6 is not set
CONFIG_CPU_TYPE="cortex-a53"
CONFIG_KERNEL_BUILD_USER="OpenWrt"
CONFIG_KERNEL_BUILD_DOMAIN="openwrt.local"

# ============================================
# Image format
# ============================================
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_SQUASHFS_BLOCK_SIZE=256
CONFIG_TARGET_UBIFS_FREE_SPACE_FIXUP=y
CONFIG_MTD_UBI=y
CONFIG_UBIFS_FS=y
CONFIG_FSTOOLS_UBIFS_EXTROOT=y

# ============================================
# Airoha hardware (EN8811H, I2C, NPU firmware)
# ============================================
CONFIG_PACKAGE_airoha-en7581-npu-firmware=y
CONFIG_PACKAGE_kmod-phy-airoha-en8811h=y
CONFIG_PACKAGE_kmod-i2c-an7581=y

# ============================================
# Ethernet, NPU, Switch
# ============================================
CONFIG_PACKAGE_kmod-airoha-eth=y
CONFIG_PACKAGE_kmod-airoha-npu=y
CONFIG_PACKAGE_kmod-airoha-switch=y
CONFIG_AIROHA_ETH=y
CONFIG_AIROHA_RESERVE_NPU_MEMORY=128M
CONFIG_PHYLIB=y
CONFIG_SWITCHDEV=y
CONFIG_NET_DSA=y
CONFIG_MDIO_BUS=y
CONFIG_KERNEL_NET_SWITCHDEV=y
CONFIG_VLAN_8021Q=y

# ============================================
# Base system
# ============================================
CONFIG_PACKAGE_base-files=y
CONFIG_PACKAGE_busybox=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_logd=y
CONFIG_PACKAGE_procd=y
CONFIG_PACKAGE_uci=y
CONFIG_PACKAGE_urandom-seed=y
CONFIG_PACKAGE_urngd=y
CONFIG_PACKAGE_netifd=y
CONFIG_PACKAGE_mtd=y
CONFIG_PACKAGE_fstools=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_libc=y
CONFIG_PACKAGE_libgcc=y
CONFIG_PACKAGE_uboot-envtools=y
CONFIG_PACKAGE_uclient-fetch=y
CONFIG_PACKAGE_kmod-gpio-button-hotplug=y
CONFIG_PACKAGE_kmod-leds-gpio=y
CONFIG_PACKAGE_kmod-ubootenv-nvram=y      # fix MAC address
CONFIG_PACKAGE_ubi-utils=y

# ============================================
# Network (IPv4 only, Firewall, Offload)
# ============================================
CONFIG_PACKAGE_dnsmasq=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_kmod-nfnetlink=y
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nf-flow=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_NFT_FLOW_OFFLOAD=y
CONFIG_PACKAGE_ethtool-full=y
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y
CONFIG_PACKAGE_kmod-ppp-mppe=y
CONFIG_PACKAGE_kmod-8021q=y

# ============================================
# SSH (Dropbear)
# ============================================
CONFIG_PACKAGE_dropbear=y
CONFIG_DROPBEAR_SMALL_CODE=y
CONFIG_DROPBEAR_ED25519=y
CONFIG_DROPBEAR_CURVE25519=y

# ============================================
# USB support（精简，移除 extras）
# ============================================
CONFIG_USB_SUPPORT=y
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-xhci-hcd=y
CONFIG_PACKAGE_kmod-usb-xhci-mtk=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
# CONFIG_PACKAGE_kmod-usb-storage-extras is not set
CONFIG_PACKAGE_kmod-usb-dwc3=y
CONFIG_PACKAGE_kmod-usb-dwc3-of-simple=y
CONFIG_PACKAGE_kmod-phy-airoha-usb=y
CONFIG_PACKAGE_usbutils=y

# ============================================
# Filesystem（精简，移除 JFFS2/UBIFS）
# ============================================
CONFIG_PACKAGE_fitblk=y
CONFIG_PACKAGE_blkid=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-squashfs=y
# CONFIG_PACKAGE_kmod-fs-ubifs is not set
# CONFIG_PACKAGE_kmod-fs-jffs2 is not set
CONFIG_PACKAGE_kmod-nls-cp437=y
CONFIG_PACKAGE_kmod-nls-iso8859-1=y
CONFIG_PACKAGE_kmod-nls-utf8=y

# ============================================
# SPI NAND / NOR (flash)
# ============================================
CONFIG_PACKAGE_kmod-spi-nand=y
CONFIG_PACKAGE_kmod-spi-nor=y
CONFIG_PACKAGE_mtd-utils=y

# ============================================
# Watchdog (hardware)
# ============================================
CONFIG_WATCHDOG=y
CONFIG_GPIO_WATCHDOG=y
CONFIG_AIROHA_WATCHDOG=y          # 新增：Airoha 专用看门狗驱动

# ============================================
# DMA 连续内存分配（NPU 和 QDMA 需要）
# ============================================
CONFIG_CMA=y
CONFIG_DMA_CMA=y

# ============================================
# I2C 总线支持
# ============================================
CONFIG_I2C=y
CONFIG_I2C_BOARDINFO=y

# ============================================
# LED 触发器（网络活动）
# ============================================
CONFIG_LEDS_TRIGGER_NETDEV=y      # 可选，用于 LED 随网络活动闪烁

# ============================================
# UBI 块设备支持（用于 rootfs 自动创建 ubiblock）
# ============================================
CONFIG_MTD_UBI_BLOCK=y            # 可选，但建议开启

# ============================================
# BBR congestion control (IPv4 only)
# ============================================
CONFIG_KERNEL_TCP_CONG_BBR=y
CONFIG_KERNEL_DEFAULT_TCP_CONG="bbr"
CONFIG_KERNEL_NET_SCH_FQ=y

# ============================================
# OpenSSL (basic)
# ============================================
CONFIG_OPENSSL_SMALL_FOOTPRINT=y
CONFIG_OPENSSL_WITH_ASM=y

# ============================================
# 安全加固选项（全部关闭）
# ============================================
# CONFIG_PKG_ASLR_PIE_REGULAR is not set
# CONFIG_PKG_CC_STACKPROTECTOR_REGULAR is not set
# CONFIG_KERNEL_CC_STACKPROTECTOR_REGULAR is not set

# ============================================
# LuCI (Web interface) - 主题 argon
# ============================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-theme-argon=y
# CONFIG_PACKAGE_luci-theme-bootstrap is not set
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-package-manager=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-attendedsysupgrade=y
CONFIG_PACKAGE_luci-compat=y

# ============================================
# Chinese language support (optional)
# ============================================
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y

# ============================================
# Additional tools
# ============================================
CONFIG_PACKAGE_umdns=y
CONFIG_PACKAGE_kmod-mtd-rw=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_fwtool=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_mdio-tools=y
