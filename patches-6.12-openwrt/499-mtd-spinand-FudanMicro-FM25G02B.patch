static int fmsh_spinand_detect(struct spinand_device *spinand)
{
	u8 *id = spinand->id.data;
	int ret;

	/* Special handling for FM25S01BI3 which uses different readid */
	if (id[0] == 0xA3 && id[1] == 0xA3 && id[2] == 0xA3 && id[3] == 0xA3) {
		spinand->manufacturer = &fmsh_spinand_manuf;
		spinand->info = &fmsh_spinand_table[1];
		return 0;
	}

	ret = spinand_match_and_init(spinand, fmsh_spinand_table,
				     ARRAY_SIZE(fmsh_spinand_table),
				     SPINAND_READID_METHOD_OPCODE_DUMMY);
	if (ret)
		return ret;

	return 0;
}

static const struct spinand_manufacturer_ops fmsh_spinand_manuf_ops = {
	.detect = fmsh_spinand_detect,
};

const struct spinand_manufacturer fmsh_spinand_manuf = {
	.name = "FMSH",
	.chips = fmsh_spinand_table,
	.nchips = ARRAY_SIZE(fmsh_spinand_table),
	.ops = &fmsh_spinand_manuf_ops,
};
