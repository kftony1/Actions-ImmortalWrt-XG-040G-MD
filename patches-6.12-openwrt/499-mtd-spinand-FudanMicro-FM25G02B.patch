#include <linux/device.h>
#include <linux/kernel.h>
#include <linux/mtd/spinand.h>

#define FMSH_SPINAND_READID_OPCODE 0x9F

static int fm25s01a_ooblayout_ecc(struct mtd_info *mtd, int section,
				  struct mtd_oob_region *region)
{
	if (section)
		return -ERANGE;

	region->offset = 64;
	region->length = 64;
	return 0;
}

static int fm25s01a_ooblayout_free(struct mtd_info *mtd, int section,
				   struct mtd_oob_region *region)
{
	if (section)
		return -ERANGE;

	region->offset = 2;
	region->length = 62;
	return 0;
}

static const struct mtd_ooblayout_ops fm25s01a_ooblayout = {
	.ecc = fm25s01a_ooblayout_ecc,
	.free = fm25s01a_ooblayout_free,
};

static int fm25s01bi3_ooblayout_ecc(struct mtd_info *mtd, int section,
				    struct mtd_oob_region *region)
{
	if (section >= 4)
		return -ERANGE;

	region->offset = 64 + section * 16;
	region->length = 16;
	return 0;
}

static int fm25s01bi3_ooblayout_free(struct mtd_info *mtd, int section,
				     struct mtd_oob_region *region)
{
	if (section)
		return -ERANGE;

	region->offset = 2;
	region->length = 62;
	return 0;
}

static const struct mtd_ooblayout_ops fm25s01bi3_ooblayout = {
	.ecc = fm25s01bi3_ooblayout_ecc,
	.free = fm25s01bi3_ooblayout_free,
};

/* ---------- Added for FM25G02B ---------- */
static int fm25g02b_ooblayout_ecc(struct mtd_info *mtd, int section,
				  struct mtd_oob_region *region)
{
	if (section >= 8)
		return -ERANGE;
	region->offset = 64 + section * 8;
	region->length = 8;

	return 0;
}

static int fm25g02b_ooblayout_free(struct mtd_info *mtd, int section,
				   struct mtd_oob_region *region)
{
	if (section)
		return -ERANGE;
	region->offset = 2;
	region->length = 62;

	return 0;
}

static const struct mtd_ooblayout_ops fm25g02b_ooblayout = {
	.ecc = fm25g02b_ooblayout_ecc,
	.free = fm25g02b_ooblayout_free,
};
/* ---------------------------------------- */

static int fm25s01bi3_ecc_get_status(struct spinand_device *spinand,
				     u8 status)
{
	/* Hardware ECC status for FM25S01BI3 */
	switch (status & STATUS_ECC_MASK) {
	case STATUS_ECC_NO_BITFLIPS:
		return 0;

	case STATUS_ECC_UNCOR_ERROR:
		return -EBADMSG;

	case STATUS_ECC_HAS_BITFLIPS:
		/* 1-4 bit flips, we cannot know exact number */
		return 4;

	default:
		return -EINVAL;
	}
}

