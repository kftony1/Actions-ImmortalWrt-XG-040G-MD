From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: OpenWrt <openwrt@openwrt.org>
Date: Mon, 18 May 2026 10:00:00 +0800
Subject: [PATCH] mtd: spinand: Add support for FudanMicro FM25G02B and other
 FMSH chips

Add SPI NAND driver for FudanMicro (FMSH) FM25G02B (2Gbit) and also
FM25S01A, FM25S01BI3, FM25S02A. Tested on FM25G02B.

Signed-off-by: OpenWrt <openwrt@openwrt.org>
---
 drivers/mtd/nand/spi/fmsh.c | 204 ++++++++++++++++++++++++++++++++++++++++++++
 1 file changed, 204 insertions(+)

diff --git a/drivers/mtd/nand/spi/fmsh.c b/drivers/mtd/nand/spi/fmsh.c
new file mode 100644
index 000000000000..81b4b9e5df7c
--- /dev/null
+++ b/drivers/mtd/nand/spi/fmsh.c
@@ -0,0 +1,204 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * Copyright (C) 2020 FMSH Corporation
+ */
+
+#include <linux/device.h>
+#include <linux/kernel.h>
+#include <linux/module.h>
+#include <linux/mtd/spinand.h>
+
+#define FMSH_SPINAND_READID_OPCODE 0x9F
+
+static int fm25s01a_ooblayout_ecc(struct mtd_info *mtd, int section,
+				  struct mtd_oob_region *region)
+{
+	if (section)
+		return -ERANGE;
+
+	region->offset = 64;
+	region->length = 64;
+	return 0;
+}
+
+static int fm25s01a_ooblayout_free(struct mtd_info *mtd, int section,
+				   struct mtd_oob_region *region)
+{
+	if (section)
+		return -ERANGE;
+
+	region->offset = 2;
+	region->length = 62;
+	return 0;
+}
+
+static const struct mtd_ooblayout_ops fm25s01a_ooblayout = {
+	.ecc = fm25s01a_ooblayout_ecc,
+	.free = fm25s01a_ooblayout_free,
+};
+
+static int fm25s01bi3_ooblayout_ecc(struct mtd_info *mtd, int section,
+				    struct mtd_oob_region *region)
+{
+	if (section >= 4)
+		return -ERANGE;
+
+	region->offset = 64 + section * 16;
+	region->length = 16;
+	return 0;
+}
+
+static int fm25s01bi3_ooblayout_free(struct mtd_info *mtd, int section,
+				     struct mtd_oob_region *region)
+{
+	if (section)
+		return -ERANGE;
+
+	region->offset = 2;
+	region->length = 62;
+	return 0;
+}
+
+static const struct mtd_ooblayout_ops fm25s01bi3_ooblayout = {
+	.ecc = fm25s01bi3_ooblayout_ecc,
+	.free = fm25s01bi3_ooblayout_free,
+};
+
+/* ---------- Added for FM25G02B ---------- */
+static int fm25g02b_ooblayout_ecc(struct mtd_info *mtd, int section,
+				  struct mtd_oob_region *region)
+{
+	if (section >= 8)
+		return -ERANGE;
+	region->offset = 64 + section * 8;
+	region->length = 8;
+
+	return 0;
+}
+
+static int fm25g02b_ooblayout_free(struct mtd_info *mtd, int section,
+				   struct mtd_oob_region *region)
+{
+	if (section)
+		return -ERANGE;
+	region->offset = 2;
+	region->length = 62;
+
+	return 0;
+}
+
+static const struct mtd_ooblayout_ops fm25g02b_ooblayout = {
+	.ecc = fm25g02b_ooblayout_ecc,
+	.free = fm25g02b_ooblayout_free,
+};
+/* ---------------------------------------- */
+
+static int fm25s01bi3_ecc_get_status(struct spinand_device *spinand,
+				     u8 status)
+{
+	/* Hardware ECC status for FM25S01BI3 */
+	switch (status & STATUS_ECC_MASK) {
+	case STATUS_ECC_NO_BITFLIPS:
+		return 0;
+
+	case STATUS_ECC_UNCOR_ERROR:
+		return -EBADMSG;
+
+	case STATUS_ECC_HAS_BITFLIPS:
+		/* 1-4 bit flips, we cannot know exact number */
+		return 4;
+
+	default:
+		return -EINVAL;
+	}
+}
+
+static const struct spinand_info fmsh_spinand_table[] = {
+	SPINAND_INFO("FM25S01A",
+		     SPINAND_ID(SPINAND_READID_METHOD_OPCODE_DUMMY, 0xA1),
+		     NAND_MEMORG(1, 2048, 64, 64, 2048, 40, 1, 1, 1),
+		     NAND_ECCREQ(4, 512),
+		     SPINAND_INFO_OP_VARIANTS(&read_cache_variants,
+					      &write_cache_variants,
+					      &update_cache_variants),
+		     SPINAND_HAS_QE_BIT,
+		     SPINAND_ECCINFO(&fm25s01a_ooblayout, NULL)),
+	SPINAND_INFO("FM25S01BI3",
+		     SPINAND_ID(SPINAND_READID_METHOD_OPCODE_DUMMY, 0xA3),
+		     NAND_MEMORG(1, 2048, 128, 64, 2048, 40, 1, 1, 1),
+		     NAND_ECCREQ(8, 528),
+		     SPINAND_INFO_OP_VARIANTS(&read_cache_variants,
+					      &write_cache_variants,
+					      &update_cache_variants),
+		     SPINAND_HAS_QE_BIT,
+		     SPINAND_ECCINFO(&fm25s01bi3_ooblayout,
+				      fm25s01bi3_ecc_get_status)),
+	/* ---------- Added for FM25G02B and FM25S02A ---------- */
+	SPINAND_INFO("FM25G02B",
+		     SPINAND_ID(SPINAND_READID_METHOD_OPCODE_DUMMY, 0xD2),
+		     NAND_MEMORG(1, 2048, 128, 64, 2048, 40, 1, 1, 1),
+		     NAND_ECCREQ(8, 528),
+		     SPINAND_INFO_OP_VARIANTS(&read_cache_variants,
+					      &write_cache_variants,
+					      &update_cache_variants),
+		     SPINAND_HAS_QE_BIT,
+		     SPINAND_ECCINFO(&fm25g02b_ooblayout, NULL)),
+	SPINAND_INFO("FM25S02A",
+		     SPINAND_ID(SPINAND_READID_METHOD_OPCODE_DUMMY, 0xE5),
+		     NAND_MEMORG(1, 2048, 64, 64, 2048, 40, 2, 1, 1),
+		     NAND_ECCREQ(2, 512),
+		     SPINAND_INFO_OP_VARIANTS(&read_cache_variants,
+					      &write_cache_variants,
+					      &update_cache_variants),
+		     0,
+		     SPINAND_ECCINFO(&fm25s01a_ooblayout, NULL)),
+	/* ----------------------------------------------------- */
+};
+
+static int fmsh_spinand_detect(struct spinand_device *spinand)
+{
+	u8 *id = spinand->id.data;
+	int ret;
+
+	/* Special handling for FM25S01BI3 which uses different readid */
+	if (id[0] == 0xA3 && id[1] == 0xA3 && id[2] == 0xA3 && id[3] == 0xA3) {
+		spinand->manufacturer = &fmsh_spinand_manuf;
+		spinand->info = &fmsh_spinand_table[1];
+		return 0;
+	}
+
+	ret = spinand_match_and_init(spinand, fmsh_spinand_table,
+				     ARRAY_SIZE(fmsh_spinand_table),
+				     SPINAND_READID_METHOD_OPCODE_DUMMY);
+	if (ret)
+		return ret;
+
+	return 0;
+}
+
+static const struct spinand_manufacturer_ops fmsh_spinand_manuf_ops = {
+	.detect = fmsh_spinand_detect,
+};
+
+const struct spinand_manufacturer fmsh_spinand_manuf = {
+	.name = "FMSH",
+	.chips = fmsh_spinand_table,
+	.nchips = ARRAY_SIZE(fmsh_spinand_table),
+	.ops = &fmsh_spinand_manuf_ops,
+};
+
+/* Module registration for OpenWrt / Linux 6.12 */
+module_spinand_manufacturer(fmsh_spinand_manuf);
+MODULE_LICENSE("GPL v2");
+MODULE_AUTHOR("FMSH Corporation");
+MODULE_DESCRIPTION("FMSH SPI NAND driver - supports FM25G02B, FM25S01A, FM25S01BI3, FM25S02A");
-- 
2.43.0
